# ============================================================
# Recon Watch Multi - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All paths can be absolute or relative to the script directory.
# ============================================================

# --- Directories & File Paths ---
ROOT_DIR=recon_data

# --- Notifications ---
NOTIFY_ID=
NOTIFY_STEP_BY_STEP=true

# Master switch for the ASN discovery stage. When false, run_asn_recon short-circuits
# to empty results and the rest of the pipeline behaves exactly as it did pre-ASN-integration.
ASN_ENABLED=true

# --- Tool Binary Paths (defaults to tool name if in PATH) ---
SUBFINDER_BIN=subfinder
HTTPX_BIN=httpx
NAABU_BIN=naabu
NUCLEI_BIN=nuclei
KATANA_BIN=katana
NOTIFY_BIN=notify
ASNMAP_BIN=asnmap
MAPCIDR_BIN=mapcidr

# --- Scan Options ---
NUCLEI_SEVERITIES=medium,high,critical
NAABU_NMAP_CLI=false
KATANA_DEPTH=2
KATANA_HEADLESS=false
KATANA_CRAWL_JS=false
KATANA_JSLUICE=false
KATANA_FIELD_SCOPE=rdn
KATANA_CUSTOM_SCOPE=

# --- JavaScript Monitoring ---
# Runs after Katana completes. Standard URLs go to nuclei while Katana-discovered
# JS files and normal HTML pages feed the recursive JS monitor in parallel.
JS_MONITOR_ENABLED=true
JS_MONITOR_THREADS=15
JS_MONITOR_TIMEOUT=30
JS_MONITOR_RECURSION_DEPTH=2
JS_MONITOR_DEEP=false
# Write Patterns file location in absolute path, e.g. /home/user/patterns.json or C:\recon\patterns.json
JS_MONITOR_PATTERNS_FILE=
JS_MONITOR_ALLOW_EXTERNAL=false

# true = pass naabu -exclude-cdn during the ASN alive-check, filtering out IPs that
# resolve to known CDN ranges (Cloudflare, Fastly, Akamai, etc). Recommended true -
# CDN-fronted IPs are noise for ASN-based org attribution and just waste naabu/nmap
# cycles later in the pipeline on infrastructure you don't actually control.
ASN_EXCLUDE_CDN=true

# --- Custom Arguments ---
# Supply extra arguments natively. e.g. SUBFINDER_ARGS="-active"
SUBFINDER_ARGS=""
HTTPX_ARGS=""
NAABU_ARGS=""
NUCLEI_ARGS=""
KATANA_ARGS=""
NOTIFY_ARGS=""
ASNMAP_ARGS=""

# --- Timeouts (seconds) ---
SUBFINDER_TIMEOUT=600
HTTPX_TIMEOUT=600
NAABU_TIMEOUT=600
NUCLEI_TIMEOUT=1200
KATANA_TIMEOUT=900
ASN_TIMEOUT=900
MAPCIDR_TIMEOUT=300
ASN_ALIVE_TIMEOUT=1800
JS_MONITOR_TOOL_TIMEOUT=900

# Hard safety cap on total expanded IPs per program per cycle. If merged CIDRs would
# expand past this count (e.g. an ASN including a /8), expansion is skipped entirely
# for that cycle rather than silently truncated - check logs and narrow scope manually,
# or raise this deliberately if you actually intend to sweep that much address space.
ASN_MAX_IPS=65536

# --- Maintenance ---
# Auto-delete scan artifact directories older than this many days (0 = disable)
MAX_JOB_RETENTION_DAYS=30

# --- Debug ---
# Set to true to skip running external tools (subfinder, httpx, etc.)
DRY_RUN=false
